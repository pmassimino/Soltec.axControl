### Zonas - Obtener todas
# @name GetUsuarios
GET {{url}}/api/usuario


### Zonas - Obtener todas
# @name GetZonas
GET {{url}}/api/zonas
Content-Type: application/json
Authorization:Bearer {{authToken}}

### Zonas - Obtener por ID
# @name GetZona
GET {{url}}/api/zonas/1

### Zonas - Crear
# @name CreateZona
POST {{url}}/api/zonas
Content-Type: application/json

{
    "nombre": "Ingreso",
    "descripcion": "Zona de entrada de vehículos",
    "orden": 1
}

### Zonas - Actualizar
# @name UpdateZona
PUT {{url}}/api/zonas/1
Content-Type: application/json

{
    "nombre": "Entrada Principal",
    "descripcion": "Zona de entrada principal de vehículos",
    "orden": 1
}

### Zonas - Eliminar
# @name DeleteZona
DELETE {{url}}/api/zonas/0

